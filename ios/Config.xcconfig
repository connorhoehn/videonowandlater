// Config.xcconfig
// Copy this file to Config.local.xcconfig and fill in real values.
// Config.local.xcconfig is gitignored — never commit real credentials.

API_URL = https://YOUR_API_GATEWAY_ID.execute-api.us-east-1.amazonaws.com/prod
COGNITO_DOMAIN = https://YOUR_COGNITO_DOMAIN.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID = YOUR_CLIENT_ID
USER_POOL_ID = us-east-1_XXXXXXXX
AWS_REGION = us-east-1
